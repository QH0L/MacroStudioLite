			SubLabel.Text = string.format("%d events • %s", #macro.events, formatTime(macro.duration or recordingLength(macro.events)))
			SubLabel.TextColor3 = Palette.TextDim
			SubLabel.TextSize = 11
			SubLabel.Font = Enum.Font.Gotham
			SubLabel.TextXAlignment = Enum.TextXAlignment.Left
			SubLabel.Parent = ItemFrame

			local LoadBtn = Instance.new("TextButton")
			LoadBtn.Size = UDim2.new(0, 48, 0, 30)
			LoadBtn.Position = UDim2.new(1, -100, 0.5, -15)
			LoadBtn.BackgroundColor3 = Palette.Accent
			LoadBtn.AutoButtonColor = false
			LoadBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
			LoadBtn.Text = "Load"
			LoadBtn.TextSize = 12
			LoadBtn.Font = Enum.Font.GothamBold
			LoadBtn.Parent = ItemFrame
			Instance.new("UICorner", LoadBtn).CornerRadius = UDim.new(0, 5)
			LoadBtn.MouseEnter:Connect(function() tween(LoadBtn, { BackgroundColor3 = Palette.Accent:Lerp(Color3.new(1,1,1), 0.15) }) end)
			LoadBtn.MouseLeave:Connect(function() tween(LoadBtn, { BackgroundColor3 = Palette.Accent }) end)

			LoadBtn.MouseButton1Click:Connect(function()
				recording = macro.events
				recordingStartTransform = macro.startTransform
				-- Use the saved duration (real elapsed time) instead of re-deriving it
				-- from the last event, so trailing pauses are respected on playback.
				recordingDuration = macro.duration or recordingLength(recording)
				timerLabel.Text = formatTime(recordingDuration)
				print("[Macro] Loaded macro: " .. macro.name .. " (" .. #recording .. " events)")
			end)

			local DeleteBtn = Instance.new("TextButton")
			DeleteBtn.Size = UDim2.new(0, 48, 0, 30)
			DeleteBtn.Position = UDim2.new(1, -48, 0.5, -15)
			DeleteBtn.BackgroundColor3 = Palette.Bad
			DeleteBtn.AutoButtonColor = false
			DeleteBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
			DeleteBtn.Text = "Del"
			DeleteBtn.TextSize = 12
			DeleteBtn.Font = Enum.Font.GothamBold
			DeleteBtn.Parent = ItemFrame
			Instance.new("UICorner", DeleteBtn).CornerRadius = UDim.new(0, 5)
			DeleteBtn.MouseEnter:Connect(function() tween(DeleteBtn, { BackgroundColor3 = Palette.Bad:Lerp(Color3.new(1,1,1), 0.15) }) end)
			DeleteBtn.MouseLeave:Connect(function() tween(DeleteBtn, { BackgroundColor3 = Palette.Bad }) end)

			DeleteBtn.MouseButton1Click:Connect(function()
				table.remove(macros, i)
				saveMacros()
				refreshMacroList()
				print("[Macro] Deleted macro: " .. macro.name)
			end)
		end
	end

	SaveBtn.MouseButton1Click:Connect(function()
		local name = NameInput.Text
		if name == "" then print("[Macro] Please enter a name for the macro.") return end
		if #recording == 0 then print("[Macro] No recording to save.") return end

		local exists = false
		for _, macro in ipairs(macros) do
			if macro.name == name then
				macro.events = recording
				macro.startTransform = recordingStartTransform
				macro.duration = recordingDuration
				exists = true
				break
			end
		end

		if not exists then
			table.insert(macros, {
				name = name,
				events = recording,
				startTransform = recordingStartTransform,
				duration = recordingDuration,
			})
		end

		saveMacros()
		refreshMacroList()
		print("[Macro] Saved macro: " .. name)
	end)

	ClearBtn.MouseButton1Click:Connect(function()
		recording = {}
		recordingStartTransform = nil
		recordingDuration = 0
		timerLabel.Text = "00:00.0"
		print("[Macro] Cleared current recording.")
	end)

	refreshMacroList()

	return TimerIcon
end

local timerIcon = createMacroGui()
-- ==========================================

-- ==========================================
-- HELPER FUNCTIONS
-- ==========================================
local function getMouseButtonValue(inputType)
	if inputType == Enum.UserInputType.MouseButton1 then return 0
	elseif inputType == Enum.UserInputType.MouseButton2 then return 1
	elseif inputType == Enum.UserInputType.MouseButton3 then return 2
	end
	return 0
end

local function viewportToScreen(x, y)
	local inset = GuiService:GetGuiInset()
	return x + inset.X, y + inset.Y
end

local function updateIndicator(viewportX, viewportY)
	Indicator.Visible = true
	Indicator.Position = UDim2.new(0, math.round(viewportX), 0, math.round(viewportY))
end

local function setStatus(text, color)
	if statusLabel then
		statusLabel.Text = text
		statusLabel.TextColor3 = color
	end
	if timerIcon then
		timerIcon.BackgroundColor3 = color
	end
end
-- ==========================================

-- ==========================================
-- LIVE TIMER LOOP
-- Runs continuously; only writes to the label while recording or playing.
-- ==========================================
task.spawn(function()
	while true do
		RunService.Heartbeat:Wait()
		if isRecording then
			timerLabel.Text = formatTime(os.clock() - startTime)
		elseif isPlaying then
			local elapsed = os.clock() - startTime
			-- keep elapsed within the current loop pass for a clean readout
			if recordingDuration > 0 then
				elapsed = elapsed % math.max(recordingDuration, 0.001)
			end
			timerLabel.Text = string.format("%s / %s", formatTime(elapsed), formatTime(recordingDuration))
		end
	end
end)
-- ==========================================

-- ==========================================
-- INPUT HANDLING & PLAYBACK
-- ==========================================
UIS.InputBegan:Connect(function(input, gameProcessed)
	-- F1 to Start/Stop Recording
	if input.KeyCode == Enum.KeyCode.F1 then
		if not isRecording then
			if isPlaying then
				print("[Macro] Cannot record while playing back.")
				return
			end
			isRecording = true
			recording = {}
			recordingStartTransform = captureStartTransform()
			startTime = os.clock()
			Indicator.Visible = false
			setStatus("Recording", Palette.Bad)
			print("[Macro] Recording started...")
		else
			isRecording = false
			-- Use real elapsed wall-clock time, NOT the last event's timestamp.
			-- This is the fix: previously recordingDuration was set from
			-- recordingLength(recording), which just reads the last event's
			-- "time" field. Any pause you held after your last click/keypress
			-- (before hitting F1) was silently discarded, so playback would
			-- finish the last input and immediately loop instead of waiting.
			recordingDuration = os.clock() - startTime
			timerLabel.Text = formatTime(recordingDuration)
			setStatus("Idle", Palette.TextDim)
			print("[Macro] Recording stopped. Recorded " .. #recording .. " events.")
		end
		return
	end

	-- F2 to Toggle Loop Playback
	if input.KeyCode == Enum.KeyCode.F2 then
		if not isRecording and #recording > 0 then
			if isPlaying then
				isPlaying = false
				print("[Macro] Loop stopped.")
			else
				isPlaying = true
				-- NOTE: recordingDuration is intentionally NOT recalculated here.
				-- It was already set correctly (real elapsed time) when recording
				-- stopped, or when a saved macro was loaded. Recomputing it from
				-- recordingLength(recording) here would re-introduce the trailing
				-- pause bug by throwing away the padding after the last event.
				setStatus("Playing", Palette.Accent)
				print("[Macro] Loop started. Press F2 to stop.")

				task.spawn(function()
					while isPlaying do
						RunService.Heartbeat:Wait()

						-- Teleport back to the recorded start position/camera (+ zoom) before
						-- each pass, but only if the "Teleport on Play" toggle is on.
						-- restoreStartTransform yields for RESTORE_SETTLE_TIME while the camera
						-- is locked, so we anchor playStartTime AFTER it returns to keep click
						-- timings accurate relative to the restored view.
						if teleportOnPlay and recordingStartTransform then
							restoreStartTransform(recordingStartTransform)
						end
						if not isPlaying then break end

						local playStartTime = os.clock()
						startTime = playStartTime -- feeds the live timer loop above
						local eventIndex = 1

						while isPlaying and eventIndex <= #recording do
							local event = recording[eventIndex]
							local targetTime = playStartTime + event.time

							while os.clock() < targetTime and isPlaying do
								RunService.Heartbeat:Wait()
							end

							if not isPlaying then break end

							if event.kind == "key" then
								-- Keyboard event: replay a key press/release via the same
								-- virtual input path used for mouse clicks.
								local keyEnum = Enum.KeyCode[event.key]
								if keyEnum then
									VIE:SendKeyEvent(event.isDown, keyEnum, false, game)
								end
							else
								-- Mouse event (default/legacy events have no "kind" field,
								-- so anything that isn't "key" is treated as a mouse click).
								local viewportX = event.x + CLICK_X_OFFSET
								local viewportY = event.y + CLICK_Y_OFFSET

								updateIndicator(viewportX, viewportY)

								local screenX, screenY = viewportToScreen(viewportX, viewportY)
								VIE:SendMouseButtonEvent(math.round(screenX), math.round(screenY), event.button, event.isDown, game, false)
							end

							eventIndex = eventIndex + 1
						end

						-- After the last recorded event finishes, wait out any remaining
						-- time in recordingDuration before looping back to the start.
						-- This is what actually preserves your trailing pause.
						if isPlaying and recordingDuration > 0 then
							local loopEndTime = playStartTime + recordingDuration
							while os.clock() < loopEndTime and isPlaying do
								RunService.Heartbeat:Wait()
							end
						end
					end

					isPlaying = false
					Indicator.Visible = false
					setStatus("Idle", Palette.TextDim)
					timerLabel.Text = formatTime(recordingDuration)
					print("[Macro] Playback fully stopped.")
				end)
			end
		else
			if isRecording then
				print("[Macro] Cannot play back: Currently recording.")
			elseif #recording == 0 then
				print("[Macro] Cannot play back: No recording exists.")
			end
		end
		return
	end

	if not isRecording then return end

	-- Record Mouse Button Presses
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 or input.UserInputType == Enum.UserInputType.MouseButton3 then
		local pos = input.Position
		table.insert(recording, {
			kind = "mouse",
			time = os.clock() - startTime,
			x = math.round(pos.X),
			y = math.round(pos.Y),
			button = getMouseButtonValue(input.UserInputType),
			isDown = true
		})
		return
	end

	-- Record Keyboard Key Presses
	if input.UserInputType == Enum.UserInputType.Keyboard and not IGNORED_KEYS[input.KeyCode] then
		table.insert(recording, {
			kind = "key",
			time = os.clock() - startTime,
			key = input.KeyCode.Name,
			isDown = true
		})
	end
end)

-- Record Mouse Button Releases / Keyboard Key Releases
UIS.InputEnded:Connect(function(input, gameProcessed)
	if not isRecording then return end

	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 or input.UserInputType == Enum.UserInputType.MouseButton3 then
		local pos = input.Position
		table.insert(recording, {
			kind = "mouse",
			time = os.clock() - startTime,
			x = math.round(pos.X),
			y = math.round(pos.Y),
			button = getMouseButtonValue(input.UserInputType),
			isDown = false
		})
		return
	end

	if input.UserInputType == Enum.UserInputType.Keyboard and not IGNORED_KEYS[input.KeyCode] then
		table.insert(recording, {
			kind = "key",
			time = os.clock() - startTime,
			key = input.KeyCode.Name,
			isDown = false
		})
	end
end)
