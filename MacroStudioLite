-- ==========================================
-- SMALL HELPERS
-- ==========================================
local function formatTime(seconds)
	seconds = math.max(0, seconds or 0)
	local mins = math.floor(seconds / 60)
	local secs = seconds - (mins * 60)
	return string.format("%02d:%04.1f", mins, secs)
end

-- Fallback only: used for legacy saved macros that don't have an explicit
-- "duration" field yet (i.e. saved before this fix). Prefer macro.duration
-- wherever possible since this undercounts any trailing pause.
local function recordingLength(events)
	if not events or #events == 0 then return 0 end
	return events[#events].time or 0
end

local function tween(instance, props, duration)
	local ok, TweenService = pcall(function() return game:GetService("TweenService") end)
	if not ok then return end
	local tw = TweenService:Create(instance, TweenInfo.new(duration or 0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props)
	tw:Play()
end
