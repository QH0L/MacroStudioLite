-- ==========================================
-- MACRO SAVING & LOADING SYSTEM
-- ==========================================
local macros = {}
local cooldown = false
local hasFileAccess = (type(writefile) == "function" and type(readfile) == "function")

local function writefileCooldown(name, data)
	if not hasFileAccess then return end
	task.spawn(function()
		if not cooldown then
			cooldown = true
			pcall(writefile, name, data, true)
		else
			repeat task.wait() until cooldown == false
			writefileCooldown(name, data)
		end
		task.wait(3)
		cooldown = false
	end)
end

local function saveMacros()
	if hasFileAccess then
		local success, encoded = pcall(function()
			return HttpService:JSONEncode(macros)
		end)
		if success then
			writefileCooldown("Macros.iy", encoded)
		end
	end
end

local function loadMacros()
	if hasFileAccess then
		local readSuccess, out = pcall(function()
			return readfile("Macros.iy", true)
		end)

		if readSuccess and out ~= "" then
			local success, response = pcall(function()
				local json = HttpService:JSONDecode(out)
				if type(json) == "table" then
					macros = json
				end
			end)

			if not success then
				print("[Macro] File Error: Corrupted JSON in Macros.iy")
			end
		end
	end
end

loadMacros()
