-- ==========================================
-- POSITION / CAMERA CAPTURE + RESTORE
-- ==========================================
local function cframeToTable(cf)
	local x, y, z, r00, r01, r02, r10, r11, r12, r20, r21, r22 = cf:GetComponents()
	return { x, y, z, r00, r01, r02, r10, r11, r12, r20, r21, r22 }
end

local function tableToCFrame(t)
	if type(t) ~= "table" or #t < 12 then return nil end
	return CFrame.new(t[1], t[2], t[3], t[4], t[5], t[6], t[7], t[8], t[9], t[10], t[11], t[12])
end

-- Captures where the player is standing/facing, where the camera is looking,
-- and how zoomed in/out the camera was (distance from the character).
-- Returns a plain table (safe to JSON-encode and store in a macro).
local function captureStartTransform()
	local data = { root = nil, camera = nil, zoom = nil }

	local character = PLR.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if root then
		data.root = cframeToTable(root.CFrame)
	end

	local camera = Workspace.CurrentCamera
	if camera then
		data.camera = cframeToTable(camera.CFrame)
		if root then
			-- Distance from the character to the camera = current zoom level.
			-- This is what actually reproduces "how zoomed out you were" —
			-- restoring camera.CFrame alone isn't enough because Roblox's
			-- default camera script re-derives the camera's distance from
			-- Player.CameraMinZoomDistance/CameraMaxZoomDistance + internal
			-- scroll state every frame, and will snap distance back to
			-- whatever it currently thinks your zoom is on the very next tick.
			data.zoom = (camera.CFrame.Position - root.Position).Magnitude
		end
	end

	return data
end

-- Teleports the character and snaps the camera to a previously captured transform,
-- including zoom distance. Waits briefly for the camera to settle before handing
-- control back to playback, since Roblox's default camera will otherwise re-follow
-- the character (position, angle, AND zoom) on the next frame.
local function restoreStartTransform(data)
	if type(data) ~= "table" then return end

	local character = PLR.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if root and data.root then
		local rootCFrame = tableToCFrame(data.root)
		if rootCFrame then
			root.CFrame = rootCFrame
		end
	end

	local camera = Workspace.CurrentCamera
	if camera and data.camera then
		local camCFrame = tableToCFrame(data.camera)
		if camCFrame then
			local originalCameraType = camera.CameraType

			-- Pin min/max zoom to the recorded distance for the duration of the
			-- settle window. This is what stops the default camera script from
			-- snapping distance back to the player's live scroll-wheel zoom the
			-- instant we hand CameraType back over.
			local originalMinZoom, originalMaxZoom
			if data.zoom then
				originalMinZoom = PLR.CameraMinZoomDistance
				originalMaxZoom = PLR.CameraMaxZoomDistance
				PLR.CameraMinZoomDistance = data.zoom
				PLR.CameraMaxZoomDistance = data.zoom
			end

			camera.CameraType = Enum.CameraType.Scriptable
			camera.CFrame = camCFrame
			task.wait(RESTORE_SETTLE_TIME)
			camera.CameraType = originalCameraType

			-- Release the zoom clamp back to whatever the player had before,
			-- now that the camera has settled at the recorded distance.
			if data.zoom then
				PLR.CameraMinZoomDistance = originalMinZoom
				PLR.CameraMaxZoomDistance = originalMaxZoom
			end
		end
	end
end
